<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes" />
  <title>Flame & Spice · Premium Dining</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700&family=Cinzel:wght@400;600;700&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body { 
      font-family: 'Inter', sans-serif; 
      background: #0b0807; 
      color: #f5f0eb; 
      overflow-x: hidden; 
    }

    .font-serif { font-family: 'Playfair Display', serif; }
    .font-cinzel { font-family: 'Cinzel', serif; }

    /* Glassmorphism */
    .glass { 
      background: rgba(20, 12, 10, 0.6); 
      backdrop-filter: blur(12px); 
      -webkit-backdrop-filter: blur(12px); 
      border-bottom: 1px solid rgba(255, 215, 0, 0.15); 
    }

    /* Enhanced Text Effects */
    .glow-gold { 
      text-shadow: 0 0 30px rgba(255, 215, 0, 0.4), 0 0 60px rgba(255, 215, 0, 0.2), 0 0 90px rgba(255, 107, 53, 0.1); 
    }

    .text-gradient-gold {
      background: linear-gradient(135deg, #ffd700 0%, #ff8c00 30%, #ffd700 60%, #ff6b35 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      background-size: 200% 200%;
      animation: shimmer 3s ease-in-out infinite;
    }

    .text-gradient-fire {
      background: linear-gradient(180deg, #fff 0%, #ffd700 40%, #ff8c00 70%, #ff4500 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .text-glow-white {
      text-shadow: 0 0 20px rgba(255,255,255,0.3), 0 0 40px rgba(255,215,0,0.1);
    }

    @keyframes shimmer {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* Buttons */
    .btn-gold { 
      background: linear-gradient(145deg, #d4a745, #b8860b); 
      box-shadow: 0 8px 32px rgba(184, 134, 11, 0.4); 
      transition: all 0.3s ease; 
    }
    .btn-gold:hover { 
      transform: translateY(-3px) scale(1.02); 
      box-shadow: 0 12px 40px rgba(184, 134, 11, 0.6); 
    }

    /* 3D Card */
    .card-3d { 
      perspective: 1000px; 
      transform-style: preserve-3d; 
      transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1); 
    }
    .card-3d:hover { 
      transform: rotateY(6deg) rotateX(4deg) scale(1.02); 
    }

    /* Masonry */
    .masonry img { 
      transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94); 
    }
    .masonry img:hover { 
      transform: scale(1.08) brightness(1.2); 
      box-shadow: 0 20px 60px rgba(255, 215, 0, 0.25); 
    }

    /* Floating Animation */
    .floating { 
      animation: float 6s ease-in-out infinite; 
    }
    @keyframes float { 
      0% { transform: translateY(0px); } 
      50% { transform: translateY(-18px); } 
      100% { transform: translateY(0px); } 
    }

    /* Carousel */
    .carousel-3d { 
      display: flex; 
      gap: 1.5rem; 
      overflow-x: auto; 
      scroll-snap-type: x mandatory; 
      padding: 2rem 0; 
    }
    .carousel-3d>* { 
      flex: 0 0 260px; 
      scroll-snap-align: start; 
    }

    .food-image { 
      width: 100%; 
      height: 180px; 
      object-fit: cover; 
      border-radius: 1rem; 
      background: #1a1412; 
    }

    /* Booking Inputs */
    .booking-input { 
      background: rgba(255, 255, 255, 0.05); 
      border: 1px solid rgba(255, 215, 0, 0.2); 
      border-radius: 1rem; 
      padding: 0.8rem 1.2rem; 
      color: #f5f0eb; 
      width: 100%; 
      transition: all 0.3s; 
    }
    .booking-input:focus { 
      outline: none; 
      border-color: #d4a745; 
      box-shadow: 0 0 20px rgba(212, 167, 69, 0.2); 
    }
    .booking-input::placeholder { 
      color: rgba(255,255,255,0.3); 
    }

    .btn-reserve { 
      background: linear-gradient(145deg, #d4a745, #b8860b); 
      border: none; 
      padding: 0.9rem; 
      border-radius: 2rem; 
      font-weight: 700; 
      letter-spacing: 0.1em; 
      color: #0b0807; 
      transition: all 0.3s; 
      width: 100%; 
    }
    .btn-reserve:hover { 
      transform: scale(1.02); 
      box-shadow: 0 8px 30px rgba(184, 134, 11, 0.5); 
    }

    /* Menu Grid */
    .menu-grid { 
      display: grid; 
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
      gap: 2rem; 
    }
    .menu-item { 
      background: rgba(20, 14, 10, 0.82); 
      border: 1px solid rgba(255,215,0,0.15); 
      border-radius: 1.5rem; 
      padding: 1.5rem; 
      transition: all 0.3s; 
      backdrop-filter: blur(12px); 
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }
    .menu-item:hover { 
      background: rgba(30, 20, 14, 0.9); 
      border-color: rgba(255,215,0,0.35); 
      transform: translateY(-6px); 
      box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 30px rgba(255,215,0,0.1); 
    }
    .menu-item img { 
      width: 100%; 
      height: 180px; 
      object-fit: cover; 
      border-radius: 1rem; 
    }
    .badge-popular { 
      background: rgba(212, 167, 69, 0.25); 
      color: #ffd700; 
      font-size: 0.65rem; 
      padding: 0.2rem 0.8rem; 
      border-radius: 2rem; 
      letter-spacing: 0.05em; 
      font-weight: 600;
    }

    /* ===== ATTRACTIVE PIZZA BACKGROUND - VISIBLE IN ALL SECTIONS ===== */
    .pizza-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: url('https://kimi-web-img.moonshot.cn/img/thumbs.dreamstime.com/9c8fb274c51f5ccf96064fc6b0d1058f57d281b4.jpg');
      background-size: cover;
      background-position: center;
      z-index: 0;
    }

    /* ===== WARM AMBER/BRONZE OVERLAY (not black!) ===== */
    .pizza-bg-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: 
        radial-gradient(ellipse at 20% 50%, rgba(139, 69, 19, 0.4) 0%, transparent 50%),
        radial-gradient(ellipse at 80% 20%, rgba(184, 134, 11, 0.3) 0%, transparent 50%),
        radial-gradient(ellipse at 50% 80%, rgba(139, 69, 19, 0.35) 0%, transparent 50%),
        linear-gradient(135deg, rgba(60, 30, 10, 0.6) 0%, rgba(40, 20, 8, 0.7) 50%, rgba(60, 30, 10, 0.6) 100%);
      z-index: 1;
    }

    /* Warm glow overlay */
    .warm-glow {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: 
        radial-gradient(circle at 30% 70%, rgba(255, 140, 0, 0.08) 0%, transparent 40%),
        radial-gradient(circle at 70% 30%, rgba(255, 215, 0, 0.06) 0%, transparent 40%);
      z-index: 2;
      pointer-events: none;
      animation: warmPulse 8s ease-in-out infinite;
    }

    @keyframes warmPulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }

    /* ===== SECTIONS - TRANSPARENT TO SHOW PIZZA BG ===== */
    .section-transparent {
      position: relative;
      z-index: 10;
    }

    /* Testimonial cards */
    .testimonial-card {
      background: rgba(20, 14, 10, 0.8);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,215,0,0.12);
      border-radius: 1.5rem;
      padding: 1.5rem;
      transition: all 0.3s;
      box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }
    .testimonial-card:hover {
      background: rgba(30, 20, 14, 0.85);
      border-color: rgba(255,215,0,0.25);
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.3), 0 0 20px rgba(255,215,0,0.05);
    }

    /* Form container */
    .form-container {
      background: rgba(20, 14, 10, 0.8);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(255,215,0,0.15);
      border-radius: 1.5rem;
      padding: 2rem;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }

    /* About card */
    .about-card {
      background: rgba(20, 14, 10, 0.8);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,215,0,0.12);
      border-radius: 1.5rem;
      padding: 2rem;
      box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }

    /* Stat box */
    .stat-box {
      background: rgba(20, 14, 10, 0.75);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,215,0,0.15);
      border-radius: 1rem;
      padding: 1rem;
      text-align: center;
      box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    }

    /* Gallery item */
    .gallery-item {
      background: rgba(20, 14, 10, 0.75);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 1rem;
      overflow: hidden;
      transition: all 0.3s;
      box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    }
    .gallery-item:hover {
      border-color: rgba(255,215,0,0.3);
      transform: scale(1.02);
      box-shadow: 0 12px 40px rgba(0,0,0,0.3), 0 0 20px rgba(255,215,0,0.1);
    }

    /* Carousel card */
    .carousel-card {
      background: rgba(20, 14, 10, 0.82);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 1.5rem;
      padding: 1rem;
      transition: all 0.3s;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }
    .carousel-card:hover {
      border-color: rgba(255,215,0,0.25);
      box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 20px rgba(255,215,0,0.1);
    }

    /* Particle effects */
    .particle {
      position: fixed;
      width: 6px;
      height: 6px;
      background: #ffd700;
      border-radius: 50%;
      pointer-events: none;
      opacity: 0;
      animation: particleFloat 4s ease-in-out infinite;
      z-index: 999;
    }

    @keyframes particleFloat {
      0%, 100% { opacity: 0; transform: translateY(0) scale(0); }
      50% { opacity: 0.6; transform: translateY(-100px) scale(1); }
    }

    /* Scroll reveal */
    .reveal {
      opacity: 0;
      transform: translateY(50px);
      transition: all 0.8s ease;
    }
    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    /* Enhanced section titles */
    .section-title {
      position: relative;
      display: inline-block;
    }
    .section-title::after {
      content: '';
      position: absolute;
      bottom: -10px;
      left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 3px;
      background: linear-gradient(90deg, transparent, #d4a745, transparent);
      border-radius: 2px;
    }

    /* Responsive */
    @media (max-width: 640px) { 
      .menu-grid { grid-template-columns: 1fr; } 
      .carousel-3d>* { flex: 0 0 200px; } 
      .food-image { height: 140px; } 
    }
  </style>
